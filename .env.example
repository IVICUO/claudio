# Anthropic, get a key at platform.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Notion, create an integration at notion.so/my-integrations and share the
# relevant pages with it. Use the Internal Integration Token here.
NOTION_API_KEY=secret_your-key-here

# ClickUp, generate a personal token at app.clickup.com/settings/apps
CLICKUP_API_KEY=your-key-here

# Slack, create an app at api.slack.com/apps, install to workspace,
# and use the Bot User OAuth Token (xoxb-).
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_TEAM_ID=T-your-team-id-here

# GitHub, create a fine grained PAT at github.com/settings/tokens.
# Required only for the admin panel to trigger workflows.
GITHUB_TOKEN=ghp_your-token-here

# Cloudflare, only needed for Worker deployment.
# Token: dash.cloudflare.com/profile/api-tokens
# Account ID: dash.cloudflare.com (right sidebar of any zone)
CLOUDFLARE_API_TOKEN=your-token-here
CLOUDFLARE_ACCOUNT_ID=your-account-id-here
